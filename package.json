{
  "name": "@e-watson/axon-logger",
  "version": "2.0.0",
  "description": "Lightweight structured logger with colored TTY output and JSON pipe mode",
  "keywords": [
    "logger",
    "logging",
    "structured",
    "json",
    "color",
    "axon"
  ],
  "homepage": "https://github.com/e-Watson-dot-ua/axon-logger#readme",
  "bugs": {
    "url": "https://github.com/e-Watson-dot-ua/axon-logger/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/e-Watson-dot-ua/axon-logger.git"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "author": {
    "name": "e-Watson",
    "url": "https://github.com/e-Watson-dot-ua"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "default": "./dist/plugin.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node --import tsx --test tests/logger.test.ts tests/plugin.test.ts",
    "prepublishOnly": "npm run lint && npm run format:check && npm run typecheck && npm test && npm run build"
  },
  "peerDependencies": {
    "@e-watson/axon": ">=0.0.1"
  },
  "peerDependenciesMeta": {
    "@e-watson/axon": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": ">=18.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.0.0"
  }
}
